# VoiceSurvey AI — environment variables
# Copy this file to .env and fill in your values.

# ── Anthropic API (required for natural AI responses) ──────────────────────
# Without this key the system falls back to deterministic rule-based responses.
# Get your key at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Twilio (required only for real phone calls) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

# ── Twilio WebRTC / operator browser (optional) ────────────────────────────
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
